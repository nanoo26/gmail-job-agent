# ── Gmail Job Agent — קובץ הגדרות לדוגמה ──────────────────────────────
# העתק קובץ זה ל-.env והגדר את הערכים המתאימים.
# הקובץ .env אינו נכלל ב-git ואינו משותף.

# ── Claude API (אופציונלי) ─────────────────────────────────────────────
# מפתח API של Anthropic להפעלת ניתוח Claude.
# השג מפתח ב- https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-...

# ── נתיב תיקיית קורות החיים ───────────────────────────────────────────
# תיקייה המכילה את קבצי ה-DOCX / PDF של קורות החיים.
# ברירת מחדל: תת-תיקייה "cvs" בספריית הפרויקט.
# שמות הקבצים הנדרשים:
#   קורות חיים - IT.docx      (מסלול IT)
#   קורות חיים - IT.pdf       (אופציונלי)
#   קורות חיים - תפעול.docx   (מסלול תפעול)
#   קורות חיים - תפעול.pdf    (אופציונלי)
#   קורות חיים - אחזקה.docx   (מסלול אחזקה)
# CV_DIR=C:\Users\me\Documents\cvs

# ── הגדרות סריקה ──────────────────────────────────────────────────────
# SCAN_ONLY_NEW=1        # סרוק רק מיילים חדשים (ברירת מחדל: 1)
# SCAN_LIMIT=60          # מספר מיילים מקסימלי לסריקה
# SCAN_DEBUG_MODE=0      # מצב debug (ברירת מחדל: 0)
# SCAN_DEBUG_LIMIT=20    # מגבלת מיילים במצב debug

# ── הגדרות Claude ──────────────────────────────────────────────────────
# CLAUDE_MODEL=claude-haiku-4-5-20251001
# CLAUDE_MAX_PER_RUN=5   # מספר מיילים מקסימלי לניתוח Claude בכל הרצה
